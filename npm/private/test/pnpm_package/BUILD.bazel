load("@bazel_lib//lib:copy_to_directory.bzl", "copy_to_directory")
load("@bazel_lib//lib:diff_test.bzl", "diff_test")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//js:defs.bzl", "js_library")
load("//npm:defs.bzl", "pnpm_extract_catalogs", "pnpm_package")
load(":mock_npm_package_store.bzl", "mock_npm_package_store")

# Extract catalogs from the test pnpm-workspace.yaml
pnpm_extract_catalogs(
    name = "pnpm_catalogs",
    workspace_manifest = "pnpm-workspace.yaml",
)

# Test 1: Verify extracted catalogs match expected output
diff_test(
    name = "test_extract_catalogs",
    file1 = ":pnpm_catalogs",
    file2 = "expected_catalogs.json",
)

# Mock workspace package providing NpmPackageStoreInfo
mock_npm_package_store(
    name = "node_modules/@test/sibling",
    package = "@test/sibling",
    version = "3.2.1",
)

# Library with workspace dep — its JsInfo carries the NpmPackageStoreInfo
js_library(
    name = "lib",
    srcs = ["index.js"],
    deps = [":node_modules/@test/sibling"],
)

# Test 2: Basic pnpm_package with catalog and workspace protocol resolution
pnpm_package(
    name = "pkg",
    srcs = [":lib"],
    package_json = "package.json",
    pnpm_catalogs = ":pnpm_catalogs",
)

copy_to_directory(
    name = "expected_pkg",
    srcs = [
        "expected_package.json",
        "index.js",
    ],
    replace_prefixes = {
        "expected_package.json": "package.json",
    },
)

diff_test(
    name = "test_pkg",
    file1 = ":pkg",
    file2 = ":expected_pkg",
)

# Test 3: pnpm_package with version override
pnpm_package(
    name = "pkg_versioned",
    srcs = [":lib"],
    package_json = "package.json",
    pnpm_catalogs = ":pnpm_catalogs",
    version = "2.0.0-rc.1",
)

copy_to_directory(
    name = "expected_pkg_versioned",
    srcs = [
        "expected_package_versioned.json",
        "index.js",
    ],
    replace_prefixes = {
        "expected_package_versioned.json": "package.json",
    },
)

diff_test(
    name = "test_pkg_versioned",
    file1 = ":pkg_versioned",
    file2 = ":expected_pkg_versioned",
)

# Test 4: pnpm_package with publishable=True invokes pnpm from the toolchain
pnpm_package(
    name = "pkg_publishable",
    srcs = [":lib"],
    package_json = "package.json",
    pnpm_catalogs = ":pnpm_catalogs",
    publishable = True,
)

sh_test(
    name = "test_publish",
    srcs = ["test_publish.sh"],
    args = ["$(locations :pkg_publishable.publish)"],
    data = [":pkg_publishable.publish"],
    tags = [
        "no-remote-exec",
        "no-sandbox",
    ],
)
