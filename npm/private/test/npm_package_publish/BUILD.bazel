load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//npm:defs.bzl", "npm_package")

npm_package(
    name = "pkg_a",
    srcs = [
        "index.d.ts",
        "index.js",
        "package.json",
    ],
    publishable = True,
)

npm_package(
    name = "pkg_b",
    srcs = [
        "index.d.ts",
        "index.js",
    ],
    publishable = True,
)

npm_package(
    name = "pkg_pnpm",
    srcs = [
        "pnpm_catalog/index.js",
        "pnpm_catalog/package.json",
    ],
    publishable = True,
    root_paths = [package_name() + "/pnpm_catalog"],
)

sh_test(
    name = "test",
    srcs = ["test.sh"],
    args = [
        "$(locations :pkg_a.publish)",
        "$(locations :pkg_b.publish)",
        "$(locations :pkg_pnpm.publish)",
        "$(locations @pnpm//:pnpm)",
        "$(locations :pkg_pnpm)",
    ],
    data = [
        ":pkg_a.publish",
        ":pkg_b.publish",
        ":pkg_pnpm",
        ":pkg_pnpm.publish",
        "@pnpm",
    ],
    tags = [
        "no-remote-exec",
        "no-sandbox",
    ],
)
