load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//npm:defs.bzl", "npm_package")

npm_package(
    name = "pkg_a",
    srcs = [
        "index.d.ts",
        "index.js",
        "package.json",
    ],
    packable = True,
    publishable = True,
)

npm_package(
    name = "pkg_b",
    srcs = [
        "index.d.ts",
        "index.js",
    ],
    publishable = True,
)

# Regression coverage: a multi-segment `out` must still land the .pack tarball on
# the declared `{name}.tgz` output (pnpm resolves --out relative to --dir).
npm_package(
    name = "pkg_nested",
    srcs = [
        "index.d.ts",
        "index.js",
        "package.json",
    ],
    out = "nested/dist",
    packable = True,
)

sh_test(
    name = "test",
    srcs = ["test.sh"],
    args = [
        "$(locations :pkg_a.publish)",
        "$(locations :pkg_b.publish)",
    ],
    data = [
        ":pkg_a.publish",
        ":pkg_b.publish",
    ],
    tags = [
        "no-remote-exec",
        "no-sandbox",
    ],
)

sh_test(
    name = "pack_test",
    srcs = ["pack_test.sh"],
    args = [
        "$(rootpath :pkg_a.pack)",
        "$(rootpath :pkg_nested.pack)",
    ],
    data = [
        ":pkg_a.pack",
        ":pkg_nested.pack",
    ],
)
